<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
	<DataCollectionRunSettings>
		<DataCollectors>
			<DataCollector friendlyName="XPlat code coverage">
				<Configuration>
					<ExcludeByFile>
						**/Program.cs;
						**/DataFileSettings.cs;
						**/Microsoft.AspNetCore.OpenApi.SourceGenerators/**/*.cs
					</ExcludeByFile>
				</Configuration>
			</DataCollector>
		</DataCollectors>
	</DataCollectionRunSettings>
</RunSettings>